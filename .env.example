# Copy this file to .env.local and fill in values

# ─── Database ──────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ─── Payment mode (demo = test/sandbox, live = real money) ─
NEXT_PUBLIC_PAYMENT_MODE=demo

# ─── Stripe (test keys — get from dashboard.stripe.com) ────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ─── Crypto / BTCPay (not needed in demo mode) ─────────────
BTCPAY_SERVER_URL=https://your-btcpay.example.com
BTCPAY_API_KEY=your_api_key
BTCPAY_STORE_ID=your_store_id
# Optional but recommended for webhook signature verification
BTCPAY_WEBHOOK_SECRET=replace_with_long_random_secret

# ─── Admin ─────────────────────────────────────────────────
ADMIN_PASSWORD=admin
ADMIN_SECRET=change-me-in-production-to-a-long-random-string

# ─── Email (demo uses mailcatcher/mailhog on localhost:1025) ─
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=orders@nordsecure.shop

# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
