# Production Environment Configuration for NordSecure
# Copy this to .env.production and fill in all required values

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL recommended for production)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@db.example.com:5432/nordsecure"
# For AWS RDS: postgresql://user:password@xxx.xxxxx.us-east-1.rds.amazonaws.com:5432/nordsecure
# For Supabase: postgresql://postgres:password@db.supabase.co:5432/postgres

# ----------------------------------------------------------------------------
# PAYMENT MODE (LIVE for production)
# ----------------------------------------------------------------------------
PAYMENT_MODE=live
NEXT_PUBLIC_PAYMENT_MODE=live

# ----------------------------------------------------------------------------
# STRIPE (Live Keys - https://dashboard.stripe.com/)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_XXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXX

# ----------------------------------------------------------------------------
# CRYPTO / BTCPay (Optional but recommended)
# ----------------------------------------------------------------------------
BTCPAY_SERVER_URL=https://your-btcpay-instance.com
BTCPAY_API_KEY=your_api_key_from_settings
BTCPAY_STORE_ID=your_store_id

# ----------------------------------------------------------------------------
# EMAIL / SMTP (Production transactional email service)
# ----------------------------------------------------------------------------
# Option 1: SendGrid (Recommended)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxxxxxxx

# Option 2: Postmark
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your_postmark_api_token
# SMTP_PASS=your_postmark_api_token

# Option 3: AWS SES
# SMTP_HOST=email-smtp.region.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=aws_ses_username
# SMTP_PASS=aws_ses_password

# General Email Settings
EMAIL_FROM=orders@nordsecure.eu
EMAIL_REPLY_TO=support@nordsecure.eu

# ----------------------------------------------------------------------------
# ADMIN AUTHENTICATION
# ----------------------------------------------------------------------------
ADMIN_PASSWORD=change-to-strong-password
ADMIN_SECRET=change-to-long-random-string-min-32-chars

# ----------------------------------------------------------------------------
# SITE CONFIGURATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://nordsecure.eu
NODE_ENV=production
